// Ingresar una calificacion e indicar si aprueba o reprueba
Algoritmo Act3_Lecc20_Inciso2_EduardoLopez
	Definir nota Como Real
	
	Escribir "Ingrese la calificación:"
    Leer nota
    
    Si nota >= 70 Entonces
        Escribir "Aprobado"
    Sino
        Escribir "Reprobado"
    FinSi
	
FinAlgoritmo
