//Determinar por un numero el nombre del mes
Algoritmo Act2_Lecc7_Inciso3_EduardoLopez
	Definir num Como Entero
	
	Escribir "Ingrese un nºmero para indicar el mes:"
	Leer num
	
	Si num=1 Entonces
		Escribir "Enero"
	SiNo
		Si num=2 Entonces
			Escribir "Febrero"
		SiNo
			Si num=3 Entonces
				Escribir "Marzo"
			Sino
                Si num = 4 Entonces
                    Escribir "Abril"
                Sino
                    Si num = 5 Entonces
                        Escribir "Mayo"
                    Sino
                        Si num = 6 Entonces
                            Escribir "Junio"
                        Sino
                            Si num = 7 Entonces
                                Escribir "Julio"
                            Sino
                                Si num = 8 Entonces
                                    Escribir "Agosto"
                                Sino
                                    Si num = 9 Entonces
                                        Escribir "Septiembre"
                                    Sino
                                        Si num = 10 Entonces
                                            Escribir "Octubre"
                                        Sino
                                            Si num = 11 Entonces
                                                Escribir "Noviembre"
                                            Sino
                                                Si num = 12 Entonces
                                                    Escribir "Diciembre"
                                                FinSi
                                            FinSi
                                        FinSi
                                    FinSi
                                FinSi
                            FinSi
                        FinSi
                    FinSi
                FinSi
				
			FinSi
		FinSi
	FinSi
	
FinAlgoritmo
